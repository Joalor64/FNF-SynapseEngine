<?xml version="1.0" encoding="utf-8"?>
<project>
	<!-- _________________________ Application Settings _________________________ -->

	<app title="Friday Night Funkin': Synapse Engine" file="SynapseEngine"
		packageName="com.joalor64.synapse" package="com.joalor64.synapse" main="Main"
		version="0.2.8" company="Joalor64" />

	<!-- NOTE TO SELF: DISABLE THIS IF ISSUES ARE FOUND -->
	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB" />

	<!-- ____________________________ Window Settings ___________________________ -->

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />
	<window if="html5" resizable="true" />
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false" />
	<window if="mac" orientation="auto" fullscreen="false" resizable="true" vsync="false"
		allow-high-dpi="true" />
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0"
		resizable="false" />

	<!-- _____________________________ Custom Defines ____________________________ -->

	<define name="MODS_ALLOWED" if="desktop" />
	<define name="HSCRIPT_ALLOWED" if="desktop" />
	<define name="LUA_ALLOWED" if="desktop" />
	<define name="ACHIEVEMENTS_ALLOWED" />
	<define name="MULTITHREADED_LOADING" />
	<define name="SHOW_LOADING_SCREEN" />
	<define name="VIDEOS_ALLOWED" if="windows || linux || android || mac" unless="32bits" />
	<define name="DISCORD_ALLOWED" if="desktop" />
	<define name="CRASH_HANDLER" if="desktop release" />
	<define name="CHECK_FOR_UPDATES" if="desktop release" />

	<!-- _____________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="export/debug" if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />

	<source path="source" />

	<assets path="assets" exclude="*.ogg" if="web" />
	<assets path="assets" exclude="*.mp3" unless="web" />

	<assets path="assets/videos" library="videos" if="VIDEOS_ALLOWED" />

	<section if="MODS_ALLOWED">
		<assets path='mods' embed='false' type='template' unless="mac" />
		<assets path='mods' embed='false' if="mac" />
		<assets path='list.txt' rename='modsList.txt' />
	</section>

	<section if="desktop">
		<assets path="alsoft.ini" if="windows" />
		<assets path="alsoft.ini" rename="alsoft.conf" unless="windows" />
	</section>

	<assets path="gamemode.ini" if="linux" />

	<!-- _______________________________ Libraries ______________________________ -->

	<haxelib name="flixel" />
	<haxelib name="flixel-addons" />
	<haxelib name="flixel-ui" />

	<haxelib name="flxanimate" />

	<haxelib name="tjson" />

	<haxelib name="hscript" />
	<haxelib name="rulescript" if="HSCRIPT_ALLOWED" />
	<haxelib name="linc_luajit" if="LUA_ALLOWED" />
	<haxelib name="hxvlc" if="VIDEOS_ALLOWED" />
	<haxelib name="hxgamemode" if="linux" />
	<haxelib name="hxdiscord_rpc" if="DISCORD_ALLOWED" />
	<haxelib name="hxcpp-debug-server" if="desktop debug" />
	<haxelib name="hxWindowColorMode" if="windows" />

	<!-- ______________________________ Haxedefines _____________________________ -->

	<!-- hxvlc Debug Stuff -->
	<haxedef name="HXC_LIBVLC_LOGGING" if="VIDEOS_ALLOWED debug" />
	<haxedef name="HXVLC_NO_SHARE_DIRECTORY" if="VIDEOS_ALLOWED" />

	<!--Enable
	the Flixel core recording system-->
	<haxedef name="FLX_RECORD" />

	<!--Disable
	the Flixel core focus lost screen-->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />

	<!--Disable
	the Flixel core debugger. Automatically gets set whenever you compile in release mode!-->
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<!--Enable
	this for Nape release builds for a serious peformance improvement-->
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

	<haxedef name="NO_PRECOMPILED_HEADERS" if="linux" />

	<haxedef name="HXCPP_CHECK_POINTER" if="CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_LINE" if="CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_TRACE" if="CRASH_HANDLER" />
	<haxedef name="HXCPP_DEBUG_LINK" if="cpp" />

	<haxedef name="HXCPP_GC_BIG_BLOCKS" />

	<haxedef name="hscriptPos" if="HSCRIPT_ALLOWED" />
	<haxedef name="analyzer-optimize" />
	<haxedef name="no-deprecation-warnings" />
	<haxedef name="message.reporting" value="pretty" />

	<!-- _______________________________ Haxe Flags ______________________________ -->

	<haxeflag name="-dce" value="no" />

	<haxeflag name="--macro" value="allowPackage('flash')" />
	<haxeflag name="--macro" value="include('my.pack')" />
	<haxeflag name="--macro"
		value="include('flixel', true, ['flixel.addons.editors.spine.*', 'flixel.addons.nape.*', 'flixel.system.macros.*'])" />

	<!-- _________________________________ Custom _______________________________ -->

	<assets path='art/icons/iconOG.png' rename='icon.png' if="linux || mac" />
	<icon path="art/icons/icon16.png" size='16' />
	<icon path="art/icons/icon32.png" size='32' />
	<icon path="art/icons/icon64.png" size='64' />
	<icon path="art/icons/iconOG.png" />

	<!-- _________________________________ Misc. _______________________________ -->

	<target id="haxe" tool="linker" if="linux">
		<lib name="/usr/lib64/libX11.so" if="HXCPP_M64" /> <!-- linux support -->
	</target>
</project>